# PostgreSQL - must match docker-compose.yml settings
POSTGRES_USER=silo_user
POSTGRES_PASSWORD=silo_pass
POSTGRES_DB=silo_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# AI Services
AI_VISION_URL=http://localhost:8001
AI_PREDICTIVE_URL=http://localhost:8002

# AI Chatbot (Ollama)
# For local development: http://localhost:11434
# For Docker: http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434
# Model name - change this to match your local Ollama model
OLLAMA_MODEL=gemma2:9b-instruct-q4_K_M

# Storage
# Windows example: UPLOADS_DIR=C:\Users\yourname\Silo\uploads
# Linux/Mac example: UPLOADS_DIR=/home/yourname/projects/Silo/uploads
UPLOADS_DIR=./uploads
